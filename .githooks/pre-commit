#!/usr/bin/env bash
# Pre-commit hook: enforce ruff + pyright + tests before every commit.
# Also regenerates the manual PDF if any doc/ files changed.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "=== ruff ==="
.venv/bin/python -m ruff check src/ tests/

echo "=== pyright ==="
.venv/bin/python -m pyright src/

echo "=== tests ==="
.venv/bin/python -m pytest tests/ -x --tb=short -q

# Regenerate manual if doc/ files or README.md changed
# (scripts/manual.sh pulls in README.md as the "Uso del software" chapter,
#  so README edits need to propagate to the PDF just like doc/ edits.)
if git diff --cached --name-only | grep -qE "^(doc/|README\.md$)"; then
    echo ""
    echo "=== manual ==="
    if command -v pandoc &>/dev/null; then
        scripts/manual.sh
        # Stage the regenerated PDF
        git add -f doc/decaf_manual.pdf
        echo "Manual PDF regenerated and staged."
    else
        echo "WARNING: pandoc not installed, skipping manual generation"
    fi
fi

echo "=== All checks passed ==="
